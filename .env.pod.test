# Example environment variables for CreativeWriter Pod
# Rename to .env.pod and edit before use

# Registry and Images
GHCR_USER=YOUR_GITHUB_USER
GHCR_IMAGE_FRONTEND=ghcr.io/${GHCR_USER}/creativewriter-public:latest
GHCR_IMAGE_SNAPSHOT=ghcr.io/marcodroll/creativewriter-public-snapshot-service:latest

# Networking
PROXY_UPSTREAM_PORT=8317
PROXY_PASSWORD=proxypal-local

# CouchDB Credentials
COUCHDB_USER=admin
COUCHDB_PASSWORD=password

# System
TZ=Europe/Berlin
DATA_PATH=./data
CONFIG_PATH=./couchdb
