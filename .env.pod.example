# Environment variables for pod-creativewriter.yaml.template
# Copy this file to .env.pod and fill in your values

# Proxy settings for host CLIProxyAPI access (pasta network)
PROXY_PASSWORD=your_cliproxy_password_here
PROXY_UPSTREAM_PORT=8317

# CouchDB credentials
COUCHDB_USER=admin
COUCHDB_PASSWORD=your_couchdb_password_here

# Container images
GHCR_IMAGE_FRONTEND=ghcr.io/your-username/creativewriter-frontend:latest
GHCR_IMAGE_SNAPSHOT=ghcr.io/your-username/creativewriter-snapshot:latest

# Paths
DATA_PATH=./data
CONFIG_PATH=./config

# Host port mapping
HOST_PORT=3080

# Timezone
TZ=Asia/Tokyo
