# Nginx Config for CLIProxyAPI Routing
# Save this as nginx/nginx-cliproxy.conf or incorporate into nginx.conf

server {
    listen 8080;
    
    # Static files
    location / {
        root /usr/share/nginx/html;
        index index.html index.htm;
        try_files $uri $uri/ /index.html;
    }

    # CouchDB API and Fauxton UI
    location /_db/ {
        client_max_body_size 100M;
        client_body_buffer_size 16M;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
        proxy_request_buffering off;

        # Talk to CouchDB on localhost within the same pod
        proxy_pass http://localhost:5984;
        rewrite ^/_db/(.*)$ /$1 break;
        
        proxy_redirect off;
        proxy_buffering off;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_pass_header Authorization;
        
        # CORS headers
        add_header Access-Control-Allow-Origin $http_origin always;
        add_header Access-Control-Allow-Credentials true always;
        add_header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS" always;
        add_header Access-Control-Allow-Headers "Accept, Authorization, Content-Type, Origin, X-Requested-With" always;
        
        if ($request_method = 'OPTIONS') {
            add_header Access-Control-Allow-Origin $http_origin;
            add_header Access-Control-Allow-Credentials true;
            add_header Access-Control-Allow-Methods 'GET, POST, PUT, DELETE, OPTIONS';
            add_header Access-Control-Allow-Headers 'Accept, Authorization, Content-Type, Origin, X-Requested-With';
            add_header Content-Type 'text/plain charset=UTF-8';
            add_header Content-Length 0;
            return 204;
        }
    }

    # Gemini Proxy via CLIProxyAPI
    location /api/gemini/ {
        # Rewrite: /api/gemini/models/gemini-pro:generateContent -> /v1beta/models/gemini-pro:generateContent
        rewrite ^/api/gemini/(.*)$ /v1beta/$1 break;
        proxy_pass ${PROXY_UPSTREAM_URL};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Replace PROXYPW_HERE with your actual CLIProxyAPI password
        proxy_set_header Authorization "Bearer ${PROXY_PASSWORD}";
        
        # SSE Streaming settings
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 300s;
        
        # CORS
        add_header Access-Control-Allow-Origin $http_origin always;
        add_header Access-Control-Allow-Credentials true always;
        add_header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS" always;
        add_header Access-Control-Allow-Headers "Accept, Authorization, Content-Type, Origin, X-Requested-With, X-API-Key" always;

        if ($request_method = 'OPTIONS') {
            add_header Access-Control-Allow-Origin $http_origin;
            add_header Access-Control-Allow-Credentials true;
            add_header Access-Control-Allow-Methods 'GET, POST, PUT, DELETE, OPTIONS';
            add_header Access-Control-Allow-Headers 'Accept, Authorization, Content-Type, Origin, X-Requested-With, X-API-Key';
            add_header Content-Type 'text/plain charset=UTF-8';
            add_header Content-Length 0;
            return 204;
        }
    }

    # Anthropic Proxy via CLIProxyAPI
    location /api/anthropic/ {
        # Rewrite: /api/anthropic/v1/messages -> /v1/messages
        rewrite ^/api/anthropic/(.*)$ /$1 break;
        proxy_pass ${PROXY_UPSTREAM_URL};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        proxy_set_header Authorization "Bearer ${PROXY_PASSWORD}";
        
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 300s;
        
        # CORS for Anthropic
        add_header Access-Control-Allow-Origin $http_origin always;
        add_header Access-Control-Allow-Credentials true always;
        add_header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS" always;
        add_header Access-Control-Allow-Headers "Accept, Authorization, Content-Type, Origin, X-Requested-With, X-API-Key, anthropic-version, anthropic-dangerous-direct-browser-access" always;

        if ($request_method = 'OPTIONS') {
            add_header Access-Control-Allow-Origin $http_origin;
            add_header Access-Control-Allow-Credentials true;
            add_header Access-Control-Allow-Methods 'GET, POST, PUT, DELETE, OPTIONS';
            add_header Access-Control-Allow-Headers 'Accept, Authorization, Content-Type, Origin, X-Requested-With, X-API-Key, anthropic-version, anthropic-dangerous-direct-browser-access';
            add_header Content-Type 'text/plain charset=UTF-8';
            add_header Content-Length 0;
            return 204;
        }
    }

    # Health check endpoint
    location /health {
        access_log off;
        return 200 'OK';
    }
}
